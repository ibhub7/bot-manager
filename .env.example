# .env — Fill this and rename to .env
# NEVER commit this file to git!

# ── Telegram (get from my.telegram.org) ─────────
API_ID=12345678
API_HASH=your_api_hash_here

# ── Master bot token (ONE bot only, from @BotFather) ──
MASTER_TOKEN=123456:ABC-your-master-bot-token

# ── MongoDB (same URI used by all child bots too) ─
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net
DB_NAME=multibot_system

# ── Your Telegram user ID(s) — space separated ───
ADMINS=123456789

# ── Dashboard ─────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
DASHBOARD_TOKEN=pick_a_strong_secret_here

# ── Optional: channel/group ID for broadcast logs ─
# Leave as 0 to disable
LOG_CHANNEL=0

# ── Session files directory ───────────────────────
SESSIONS_DIR=sessions

# ── Broadcast tuning (defaults are good to start) ─
BATCH_SIZE=80
CONCURRENCY=15
MIN_DELAY=0.05
MAX_DELAY=0.15
BOT_RATE_LIMIT=25
